# Cache — regenerated automatically, no need to store in Git
cache/

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Environment / secrets — never commit your API key
.env
*.env

# Streamlit secrets — NEVER commit this file
.streamlit/secrets.toml

# Mac system files
.DS_Store

# The nested screener-v3 working copy (duplicate of root files)
screener-v3/

# Database file — regenerated automatically on first run
auth.db
*.db
*.sqlite
*.sqlite3

# Python virtual environment folders
venv/
.venv/
env/

# VS Code / editor settings
.vscode/
.idea/

# Streamlit local config (not secrets, just personal preferences)
.streamlit/config.toml

# Cache seed — committed snapshot used to pre-warm Render on deploy
!cache-seed/
!cache-seed/**

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
!.env.example
